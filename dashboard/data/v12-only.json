  "config": {
    "name": "v12-aggressive-timeouts",
    "yamlPath": "configs/v12-aggressive-timeouts.yaml",
    "yaml": "# V12-AGGRESSIVE-TIMEOUTS \u2014 Hypothesis-driven timeout optimization.\n#\n# Building on v11's validated baseline, v12 tests 3 timeout reductions:\n#\n#   H1: connectTimeout 1000ms \u2192 500ms\n#       Theory: After BG switchover, stale writer IP is unreachable. Each\n#       HikariCP connection attempt waits connectTimeout before giving up.\n#       Halving this should reduce BG recovery by ~0.5-1s per pool refill cycle.\n#       Risk: wrapper 4.0.1 failover2 plugin may handle this better than v6-era\n#       wrapper 3.x which broke at 500ms.\n#\n#   H2: failureDetectionTime 6000ms \u2192 3000ms\n#       Theory: EFM2 waits failureDetectionTime before starting to probe the\n#       writer. Current 6s delay dominates FO median (8.2s \u2248 6s delay + 2s actual).\n#       Halving to 3s should bring FO median to ~5s.\n#       Risk: If Aurora writer has legitimate 3-6s stalls (GC, IO), this could\n#       trigger false-positive failover detection. Mitigated by keeping\n#       failureDetectionCount=3 (still needs 3 consecutive failures).\n#\n#   H3: socketTimeout 3000ms \u2192 1500ms\n#       Theory: In-flight queries on stale connections wait socketTimeout before\n#       timing out. At 1500ms, stale connections are released faster, allowing\n#       HikariCP to refill sooner.\n#       Risk: Slow queries > 1.5s would be killed. Our workload is simple CRUD\n#       (single-row read/insert/update), max expected query time ~50ms.\n#\n# Unchanged from v11:\n#   - Same workload (1280 ops/s, pool=50, 10Hz STATS)\n#   - Same JVM flags (DNS TTL=5, negative TTL=2)\n#   - Same plugin chain (failover2, efm2, bg)\n#   - Same HikariCP pool config\n#   - Same infrastructure (CDK, 5-cluster parallel)\n#\n# Expected results vs v11:\n#   BG: 4.4s \u2192 ~3.5s (H1 effect)\n#   FO: 8.2s \u2192 ~5.0s (H2 effect, biggest expected win)\n#   RB: 6.6s \u2192 ~5.5s (H3 effect)\n#\n# Required JVM flags:\n#   -Dnetworkaddress.cache.ttl=5\n#   -Dnetworkaddress.cache.negative.ttl=2\n#   --add-opens java.base/java.lang=ALL-UNNAMED\n#   --add-opens java.base/java.lang.reflect=ALL-UNNAMED\n#   -Xmx2g\n#\nname: v12-aggressive-timeouts\ndescription: v11 baseline + 3 timeout reductions (connectTimeout 500, failureDetectionTime 3000, socketTimeout 1500)\n\ndatabase:\n  port: 4488\n  database: demo\n  tableTemplate: \"table_${CONFIG}_${SUFFIX}\"\n  user: admin\n\njdbc:\n  wrapperPlugins:\n    - failover2\n    - efm2\n    - bg\n  bgHighMs: 50\n  # H1: connectTimeout 1000 \u2192 500ms\n  connectTimeout: 500\n  # H3: socketTimeout 3000 \u2192 1500ms\n  socketTimeout: 1500\n  # H2: failureDetectionTime 6000 \u2192 3000ms\n  failureDetectionTime: 3000\n  failureDetectionInterval: 1000\n  failureDetectionCount: 3\n  wrapperLoggerLevel: INFO\n\nhikari:\n  maximumPoolSize: 50\n  minimumIdle: 50\n  initializationFailTimeout: -1\n  connectionTimeoutMs: 5000\n  idleTimeoutMs: 30000\n  maxLifetimeMs: 60000\n  keepaliveTimeMs: 60000\n  validationTimeoutMs: 5000\n  connectionInitSql: \"select 1 from dual\"\n  connectionTestQuery: \"SELECT 1\"\n  exceptionOverrideClassName: software.amazon.jdbc.util.HikariCPSQLException\n\nworkload:\n  threads: 64\n  intervalMs: 50\n  weights:\n    read: 9\n    insert: 2\n    update: 1\n  retry:\n    enabled: true\n    delayMs: 25\n  statsReporterHz: 10\n",
    "highlights": [
