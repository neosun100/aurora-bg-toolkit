<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.aurora</groupId>
    <artifactId>aurora-bg-toolkit</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>Aurora BG Toolkit</name>
    <description>
        A reproducible, configuration-driven test harness for measuring Aurora MySQL
        Blue/Green switchover, Failover, and Reboot downtime.
    </description>
    <url>https://github.com/neosun100/aurora-bg-toolkit</url>

    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Library versions (override via -D on command line) -->
        <!--
          AWS Advanced JDBC Wrapper:
          The original HSK engagement tested 3.3.0 and 4.0.0. Those versions are
          published only on GitHub Releases, NOT on Maven Central. We download them
          via lib/ + ./scripts/install-local-wrapper-jars.sh into the local Maven
          repository before building.
          Default = 4.0.0 (the engagement's terminal version). Switch via profile.
        -->
        <wrapper.version>4.0.0</wrapper.version>
        <mysql.connector.version>8.0.33</mysql.connector.version>
        <hikaricp.version>4.0.3</hikaricp.version>
        <slf4j.version>2.0.13</slf4j.version>
        <snakeyaml.version>2.2</snakeyaml.version>

        <!-- Test versions -->
        <junit.version>5.10.2</junit.version>
        <assertj.version>3.25.3</assertj.version>
        <testcontainers.version>1.21.3</testcontainers.version>
        <docker-java.version>3.5.1</docker-java.version>
        <mockito.version>5.11.0</mockito.version>

        <!-- Plugin versions -->
        <maven.compiler.plugin>3.13.0</maven.compiler.plugin>
        <maven.surefire.plugin>3.2.5</maven.surefire.plugin>
        <maven.failsafe.plugin>3.2.5</maven.failsafe.plugin>
        <maven.shade.plugin>3.5.2</maven.shade.plugin>
        <maven.jar.plugin>3.4.1</maven.jar.plugin>
    </properties>

    <dependencies>
        <!-- AWS Advanced JDBC Wrapper -->
        <dependency>
            <groupId>software.amazon.jdbc</groupId>
            <artifactId>aws-advanced-jdbc-wrapper</artifactId>
            <version>${wrapper.version}</version>
        </dependency>

        <!-- MySQL JDBC Driver -->
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
            <version>${mysql.connector.version}</version>
        </dependency>

        <!-- HikariCP Connection Pool (4.0.3 to match customer's environment) -->
        <dependency>
            <groupId>com.zaxxer</groupId>
            <artifactId>HikariCP</artifactId>
            <version>${hikaricp.version}</version>
        </dependency>

        <!-- SLF4J -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>${slf4j.version}</version>
        </dependency>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-simple</artifactId>
            <version>${slf4j.version}</version>
        </dependency>

        <!-- YAML config -->
        <dependency>
            <groupId>org.yaml</groupId>
            <artifactId>snakeyaml</artifactId>
            <version>${snakeyaml.version}</version>
        </dependency>

        <!-- ===== Test Dependencies ===== -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>${assertj.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <version>${mockito.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <version>${testcontainers.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>mysql</artifactId>
            <version>${testcontainers.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${testcontainers.version}</version>
            <scope>test</scope>
        </dependency>
        <!-- Force a newer docker-java than testcontainers ships,
             so we can talk to Docker daemons that require API >= 1.40
             (OrbStack, modern Docker Engine). -->
        <dependency>
            <groupId>com.github.docker-java</groupId>
            <artifactId>docker-java-api</artifactId>
            <version>${docker-java.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.github.docker-java</groupId>
            <artifactId>docker-java-transport-zerodep</artifactId>
            <version>${docker-java.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>aurora-bg-toolkit</finalName>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven.compiler.plugin}</version>
                <configuration>
                    <release>17</release>
                </configuration>
            </plugin>

            <!-- Unit tests: run during 'test' phase -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${maven.surefire.plugin}</version>
                <configuration>
                    <includes>
                        <include>**/unit/**/*Test.java</include>
                        <include>**/unit/**/*Tests.java</include>
                    </includes>
                    <argLine>
                        --add-opens java.base/java.lang=ALL-UNNAMED
                        --add-opens java.base/java.lang.reflect=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>

            <!-- Integration & regression tests: run during 'verify' phase -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <version>${maven.failsafe.plugin}</version>
                <configuration>
                    <includes>
                        <include>**/integration/**/*IT.java</include>
                        <include>**/integration/**/*ITs.java</include>
                        <include>**/regression/**/*RT.java</include>
                    </includes>
                    <argLine>
                        --add-opens java.base/java.lang=ALL-UNNAMED
                        --add-opens java.base/java.lang.reflect=ALL-UNNAMED
                    </argLine>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- Shade plugin: build a fat-jar with all deps for easy deployment -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>${maven.shade.plugin}</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <shadedArtifactAttached>true</shadedArtifactAttached>
                            <shadedClassifierName>all</shadedClassifierName>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>com.aurora.bgtest.BgDowntimeTest</mainClass>
                                </transformer>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Profile: skip integration tests (Testcontainers requires Docker) -->
        <profile>
            <id>unit-only</id>
            <activation>
                <property>
                    <name>skipITs</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-failsafe-plugin</artifactId>
                        <configuration>
                            <skipITs>true</skipITs>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Profile: pin to AWS JDBC Wrapper 2.5.x for testing rollback scenarios -->
        <profile>
            <id>wrapper-2.5</id>
            <properties>
                <wrapper.version>2.5.6</wrapper.version>
            </properties>
        </profile>

        <!-- Profile: AWS JDBC Wrapper 3.3.0 (matches original HSK engagement, EC2 wrapper3 / EKS wrapper3) -->
        <profile>
            <id>wrapper-3.3</id>
            <properties>
                <wrapper.version>3.3.0</wrapper.version>
            </properties>
        </profile>

        <!-- Profile: AWS JDBC Wrapper 4.0.0 (default; matches HSK terminal version) -->
        <profile>
            <id>wrapper-4.0</id>
            <activation>
                <activeByDefault>false</activeByDefault>
            </activation>
            <properties>
                <wrapper.version>4.0.0</wrapper.version>
            </properties>
        </profile>

        <!-- Profile: AWS JDBC Wrapper 4.0.1 (latest; bugfix release on top of 4.0.0) -->
        <profile>
            <id>wrapper-4.1</id>
            <properties>
                <wrapper.version>4.0.1</wrapper.version>
            </properties>
        </profile>

        <!-- Profile: fall back to Maven Central 2.6.0 (no GitHub-only jars required).
             Useful for CI environments where install-local-wrapper-jars.sh has not run. -->
        <profile>
            <id>wrapper-mvncentral</id>
            <properties>
                <wrapper.version>2.6.0</wrapper.version>
            </properties>
        </profile>
    </profiles>
</project>
